AAO,oBAAA;AAAA,MACpH,EAAE,KAAK,sGAAsG,OAAO,iBAAA;AAAA,MACpH,EAAE,KAAK,sGAAsG,OAAO,iBAAA;AAAA,MACpH,EAAE,KAAK,sGAAsG,OAAO,iBAAA;AAAA,MACpH,EAAE,KAAK,sGAAsG,OAAO,cAAA;AAAA,IAAc;;;QAKzH,IAAG;AAAA,QAAQ,OAAM;AAAA,MAAA,sKAKmEA,MAAA,MAAA,KAAM,SAAA,CAAA,6IAGiBA,MAAA,MAAA,KAAM,SAAA,CAAA;oBAQjG,OAAK,CAAd,GAAG,MAAC;;;0BAEgD,KAAK,IAAI,IAAC,IAAA,GAAA,CAAA,CAAA;AAAA,UAA4BA,MAAA,MAAA,KAAM;AAAA;iCAQrG,OAAK,EAAE,GAAG,kBACV,OAAK,EAAE,KAAK,uUAK4D,EAAE,MAAM,YAAA,CAAW;;;;;;;;;;;;;;;;AC7CxG,UAAM,EAAU,OAAA,IAAW,UAAA;AAE3B,UAAM,WAAW;AAAA,MACf;AAAA,QACE,MAAM;AAAA,QACN,QAAQ;AAAA,QACR,MAAM;AAAA,QACN,WAAW;AAAA,QACX,KAAK;AAAA,QACL,KAAK;AAAA,MAAA;AAAA,MAEP;AAAA,QACE,MAAM;AAAA,QACN,QAAQ;AAAA,QACR,MAAM;AAAA,QACN,WAAW;AAAA,QACX,KAAK;AAAA,QACL,KAAK;AAAA,MAAA;AAAA,IACP;;;QAKS,IAAG;AAAA,QAAU,OAAM;AAAA,MAAA,sKAKiEA,MAAA,MAAA,KAAM,SAAA,CAAA,+IAGiBA,MAAA,MAAA,KAAM,SAAA,CAAA;oBAQjG,UAAQ,CAAjB,GAAG,MAAC;6BAEuBM,eAAA,CAAA,UAAA,gBAAA,SAASN,MAAA,MAAA,KAAM,WAAA,qBAAA,CAAA,2EAI7C,OAAK,EAAE,GAAG,kBACV,OAAK,EAAE,IAAI,0PAM8DE,eAAA,EAAE,IAAI,6EACRA,eAAA,EAAE,MAAM,yJAINA,eAAA,EAAE,IAAI,uFAENA,eAAA,EAAE,SAAS,8DAC9BA,eAAA,EAAE,GAAG;;;;;;;;;;;;;;;;AC5D1E,UAAM,EAAU,OAAA,IAAW,UAAA;AAE3B,UAAM,QAAQ;AAAA,MACZ,EAAE,KAAK,MAAM,OAAO,OAAiB,MAAM,+BAAA;AAAA,MAC3C,EAAE,KAAK,MAAM,OAAO,WAAc,MAAM,wBAAA;AAAA,MACxC,EAAE,KAAK,MAAM,OAAO,MAAkB,MAAM,8BAAA;AAAA,MAC5C,EAAE,KAAK,MAAM,OAAO,YAAY,MAAM,4BAAA;AAAA,IAA4B;;;QAKzD,IAAG;AAAA,QAAO,OAAM;AAAA,MAAA,sKAKoEF,MAAA,MAAA,KAAM,SAAA,CAAA,oJAGiBA,MAAA,MAAA,KAAM,SAAA,CAAA;oBAQjG,OAAK,CAAd,GAAG,MAAC;;;0BAEgD,IAAC,CAAA;AAAA,UAAoBA,MAAA,MAAA,KAAM;AAAA;iGAQFE,eAAA,EAAE,GAAG,kHAE5BA,eAAA,EAAE,KAAK,+DACZA,eAAA,EAAE,IAAI;;;;;;;;;;;;;;;;ACxCzE,UAAM,EAAU,OAAA,IAAW,UAAA;;;QAIhB,IAAG;AAAA,QAAU,OAAM;AAAA,MAAA,+JAE+DF,MAAA,MAAA,KAAM,SAAA,CAAA,+KAG6CA,MAAA,MAAA,KAAM,SAAA,CAAA,kIAGzDA,MAAA,MAAA,KAAM,SAAA,CAAA,oIAKtBA,MAAA,MAAA,KAAM,SAAA,CAAA,goEAwBPA,MAAA,MAAA,KAAM,SAAA,CAAA;;;;;;;;;;;;;;ACzClF,UAAM,EAAU,OAAA,IAAW,UAAA;AAE3B,UAAM,OAAO;AAAA,MACX,EAAE,OAAO,MAAQ,OAAO,2BAAA;AAAA,MACxB,EAAE,OAAO,QAAQ,OAAO,+CAAA;AAAA,MACxB,EAAE,OAAO,OAAU,OAAO,eAAA;AAAA,MAC1B,EAAE,OAAO,QAAQ,OAAO,4BAAA;AAAA,MACxB,EAAE,OAAO,OAAO,OAAO,QAAA;AAAA,IAAQ;;;QAKtB,IAAG;AAAA,QAAS,OAAM;AAAA,MAAA,sKAKkEA,MAAA,MAAA,KAAM,SAAA,CAAA,8IAGiBA,MAAA,MAAA,KAAM,SAAA,CAAA,+HAO5FA,MAAA,MAAA,KAAM,SAAA,CAAA,wdAY6BA,MAAA,MAAA,KAAM,SAAA,CAAA;AAE9CC,oBAAA,OAAR,SAAI;2KAI+DC,eAAA,KAAK,KAAK,gEACzBA,eAAA,KAAK,KAAK;;;;;;;;;;;;;;kBC9CvEE,eAAAC,WAAA,EAAA,OAAM,4DAA2D,GAAA,MAAA,CAAA,8lDAqB1DH,gBAAA,oBAAA,KAAI,GAAG,YAAW,CAAA;;;;;;;;;;;;;ACrBnC,YAAQ;AAAA,MACN,OAAO;AAAA,IAAA,CACR;;;;;;;;;;;;AAIM,YAAA,OAAAE,eAAAC,WAAA,EAAA,OAAM,8BAA0B,MAAA,CAAA,CAAA,GAAA;;;;;;;;;;;;;;;;;;;;;;;","names":["_unref","_ssrRenderList","_ssrInterpolate","_ssrRenderAttr","_ssrRenderAttrs","_mergeProps","_ssrRenderClass"],"sources":["../../../../components/SiteNav.vue","../../../../components/HeroSection.vue","../../../../composables/useInView.ts","../../../../components/ConceptSection.vue","../../../../components/ServiceSection.vue","../../../../components/WorksSection.vue","../../../../components/StylistSection.vue","../../../../components/FlowSection.vue","../../../../components/ReserveSection.vue","../../../../components/AccessSection.vue","../../../../components/SiteFooter.vue","../../../../pages/index.vue"],"sourcesContent":["<script setup lang=\"ts\">\nconst scrolled = ref(false)\nconst menuOpen = ref(false)\n\nconst links = [\n  { label: 'Concept', href: '#concept' },\n  { label: 'Service', href: '#service' },\n  { label: 'Works',   href: '#works'   },\n  { label: 'Reserve', href: '#reserve' },\n  { label: 'Access',  href: '#access'  },\n]\n\nonMounted(() => {\n  const onScroll = () => { scrolled.value = window.scrollY > 60 }\n  window.addEventListener('scroll', onScroll, { passive: true })\n  onUnmounted(() => window.removeEventListener('scroll', onScroll))\n})\n</script>\n\n<template>\n  <header\n    :class=\"[\n      'fixed top-0 left-0 right-0 z-50 transition-all duration-500',\n      scrolled ? 'bg-blanc-bg/95 backdrop-blur-sm border-b border-blanc-accent/20' : 'bg-transparent',\n    ]\"\n  >\n    <div class=\"max-w-6xl mx-auto px-8 py-5 flex items-center justify-between\">\n      <a href=\"#\" class=\"font-josefin text-blanc-primary text-xs tracking-[0.4em] font-light\">\n        atelier BLANC\n      </a>\n\n      <!-- Desktop -->\n      <nav class=\"hidden md:flex gap-10\">\n        <a\n          v-for=\"l in links\"\n          :key=\"l.label\"\n          :href=\"l.href\"\n          class=\"font-josefin text-[11px] tracking-[0.25em] text-blanc-muted hover:text-blanc-primary transition-colors duration-300\"\n        >\n          {{ l.label }}\n        </a>\n      </nav>\n\n      <!-- Mobile hamburger -->\n      <button\n        class=\"md:hidden flex flex-col gap-1.5 p-1\"\n        :aria-label=\"menuOpen ? 'メニューを閉じる' : 'メニューを開く'\"\n        @click=\"menuOpen = !menuOpen\"\n      >\n        <span :class=\"['block w-5 h-px bg-blanc-primary transition-all duration-300', menuOpen ? 'rotate-45 translate-y-2' : '']\" />\n        <span :class=\"['block w-5 h-px bg-blanc-primary transition-all duration-300', menuOpen ? 'opacity-0' : '']\" />\n        <span :class=\"['block w-5 h-px bg-blanc-primary transition-all duration-300', menuOpen ? '-rotate-45 -translate-y-2.5' : '']\" />\n      </button>\n    </div>\n\n    <!-- Mobile menu -->\n    <Transition name=\"slide\">\n      <div\n        v-if=\"menuOpen\"\n        class=\"md:hidden bg-blanc-bg/98 border-t border-blanc-accent/20 px-8 py-8 flex flex-col gap-6\"\n      >\n        <a\n          v-for=\"l in links\"\n          :key=\"l.label\"\n          :href=\"l.href\"\n          class=\"font-josefin text-sm tracking-[0.25em] text-blanc-muted hover:text-blanc-primary transition-colors\"\n          @click=\"menuOpen = false\"\n        >\n          {{ l.label }}\n        </a>\n      </div>\n    </Transition>\n  </header>\n</template>\n\n<style scoped>\n.slide-enter-active, .slide-leave-active { transition: opacity 0.3s ease, transform 0.3s ease; }\n.slide-enter-from, .slide-leave-to { opacity: 0; transform: translateY(-8px); }\n</style>\n","<template>\n  <section class=\"relative min-h-screen grid md:grid-cols-2 overflow-hidden\">\n    <!-- Left: text -->\n    <div class=\"flex flex-col justify-center px-10 md:px-16 lg:px-24 pt-32 pb-20 md:pt-0 md:pb-0 bg-blanc-bg\">\n      <p class=\"hero-label font-josefin text-[10px] tracking-[0.5em] text-blanc-accent mb-8\">\n        PRIVATE HAIR SALON\n      </p>\n      <span class=\"hero-label thin-rule mb-10\" />\n      <h1 class=\"hero-title font-garamond text-4xl md:text-5xl lg:text-6xl italic font-light leading-snug text-blanc-primary mb-8\">\n        あなたらしさを、<br />解放する場所。\n      </h1>\n      <p class=\"hero-body font-jp text-sm text-blanc-muted leading-8 mb-12 max-w-xs\">\n        骨格・ライフスタイルに寄り添う、<br />完全プライベートサロン。\n      </p>\n      <a\n        href=\"#reserve\"\n        class=\"hero-cta self-start font-josefin text-[11px] tracking-[0.35em] text-blanc-primary border border-blanc-primary px-10 py-4 hover:bg-blanc-primary hover:text-blanc-white transition-all duration-400\"\n      >\n        ご予約はこちら\n      </a>\n    </div>\n\n    <!-- Right: image -->\n    <div class=\"relative h-72 md:h-auto hero-image\">\n      <img\n        src=\"https://images.pexels.com/photos/3993449/pexels-photo-3993449.jpeg?auto=compress&cs=tinysrgb&w=900\"\n        alt=\"atelier BLANC サロンイメージ\"\n        class=\"absolute inset-0 w-full h-full object-cover object-center\"\n      />\n      <!-- Subtle overlay to tie into bg color -->\n      <div class=\"absolute inset-0 bg-blanc-primary/5\" />\n    </div>\n  </section>\n</template>\n","export function useInView(threshold = 0.15) {\n  const target = ref<HTMLElement | null>(null)\n  const inView = ref(false)\n\n  onMounted(() => {\n    if (!target.value) return\n    const observer = new IntersectionObserver(\n      ([entry]) => { if (entry.isIntersecting) inView.value = true },\n      { threshold },\n    )\n    observer.observe(target.value)\n    onUnmounted(() => observer.disconnect())\n  })\n\n  return { target, inView }\n}\n","<script setup lang=\"ts\">\nconst { target, inView } = useInView()\n</script>\n\n<template>\n  <section id=\"concept\" class=\"bg-blanc-light py-28 md:py-44 px-6\">\n    <div ref=\"target\" class=\"max-w-2xl mx-auto text-center\">\n      <p :class=\"['reveal font-josefin text-[10px] tracking-[0.5em] text-blanc-accent mb-10', inView && 'in-view']\">\n        CONCEPT\n      </p>\n\n      <!-- Decorative rule -->\n      <div :class=\"['reveal reveal-delay-1 flex items-center gap-6 justify-center mb-12', inView && 'in-view']\">\n        <span class=\"block flex-1 h-px bg-blanc-accent/40 max-w-[80px]\" />\n        <span class=\"font-garamond text-blanc-accent text-xl italic\">B</span>\n        <span class=\"block flex-1 h-px bg-blanc-accent/40 max-w-[80px]\" />\n      </div>\n\n      <h2 :class=\"['reveal reveal-delay-2 font-garamond text-3xl md:text-4xl lg:text-5xl italic font-light text-blanc-primary leading-snug mb-10', inView && 'in-view']\">\n        あなた一人のために<br />存在するサロン。\n      </h2>\n\n      <p :class=\"['reveal reveal-delay-3 font-jp text-sm text-blanc-muted leading-9 mb-6', inView && 'in-view']\">\n        atelier BLANCは、あなた一人のために存在するプライベートサロンです。\n      </p>\n      <p :class=\"['reveal reveal-delay-3 font-jp text-sm text-blanc-muted leading-9', inView && 'in-view']\">\n        トレンドではなく、あなたの魅力を最大限に引き出すスタイルをご提案します。骨格・髪質・ライフスタイルを丁寧に読み解き、唯一無二の一スタイルを共に作り上げます。\n      </p>\n\n      <!-- Bottom rule -->\n      <div :class=\"['reveal reveal-delay-4 flex items-center gap-6 justify-center mt-12', inView && 'in-view']\">\n        <span class=\"block flex-1 h-px bg-blanc-accent/40 max-w-[80px]\" />\n        <span class=\"font-garamond text-blanc-accent text-xl italic\">◇</span>\n        <span class=\"block flex-1 h-px bg-blanc-accent/40 max-w-[80px]\" />\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\nconst { target, inView } = useInView()\n\nconst services = [\n  { name: 'Cut',          jp: 'カット',          price: '¥8,800〜',  duration: '約60分', desc: '骨格・髪質を診断し、あなたに最も似合うフォルムを提案します。' },\n  { name: 'Color',        jp: 'カラー',          price: '¥12,100〜', duration: '約120分', desc: '繊細なカラーリングで、肌トーンを美しく引き立てる色を選びます。' },\n  { name: 'Perm',         jp: 'パーマ',          price: '¥14,300〜', duration: '約150分', desc: 'ダメージを最小限に抑えた薬剤で、自然なウェーブを。' },\n  { name: 'Treatment',    jp: 'トリートメント',  price: '¥5,500〜',  duration: '約45分',  desc: '髪の内部から補修し、しなやかな艶と手触りを取り戻します。' },\n]\n</script>\n\n<template>\n  <section id=\"service\" class=\"bg-blanc-bg py-28 md:py-40 px-6\">\n    <div ref=\"target\" class=\"max-w-5xl mx-auto\">\n\n      <!-- Heading -->\n      <div class=\"mb-16\">\n        <p :class=\"['reveal font-josefin text-[10px] tracking-[0.5em] text-blanc-accent mb-4', inView && 'in-view']\">\n          SERVICE\n        </p>\n        <h2 :class=\"['reveal reveal-delay-1 font-garamond text-4xl md:text-5xl italic font-light text-blanc-primary', inView && 'in-view']\">\n          Menu\n        </h2>\n      </div>\n\n      <!-- Cards -->\n      <div class=\"grid sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n        <div\n          v-for=\"(s, i) in services\"\n          :key=\"s.name\"\n          :class=\"[\n            'reveal',\n            `reveal-delay-${Math.min(i + 1, 4)}`,\n            inView && 'in-view',\n            'group p-8 border border-blanc-light bg-blanc-white hover:bg-blanc-light transition-colors duration-400 flex flex-col gap-5',\n          ]\"\n        >\n          <div>\n            <p class=\"font-josefin text-[10px] tracking-[0.4em] text-blanc-accent mb-2\">{{ s.name.toUpperCase() }}</p>\n            <p class=\"font-garamond text-2xl italic font-light text-blanc-primary\">{{ s.jp }}</p>\n          </div>\n          <div class=\"h-px bg-blanc-accent/30\" />\n          <div class=\"flex-1\">\n            <p class=\"font-jp text-xs text-blanc-muted leading-7\">{{ s.desc }}</p>\n          </div>\n          <div>\n            <p class=\"font-garamond text-xl text-blanc-primary\">{{ s.price }}</p>\n            <p class=\"font-josefin text-[10px] tracking-widest text-blanc-muted mt-1\">{{ s.duration }}</p>\n          </div>\n        </div>\n      </div>\n\n      <p :class=\"['reveal font-jp text-[11px] text-blanc-muted mt-10', inView && 'in-view']\">\n        ※ 価格はすべて税込です。施術内容により変動する場合があります。\n      </p>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\nconst { target, inView } = useInView()\n\nconst works = [\n  { src: 'https://images.pexels.com/photos/1325735/pexels-photo-1325735.jpeg?auto=compress&cs=tinysrgb&w=600', label: 'Blonde Bob Cut' },\n  { src: 'https://images.pexels.com/photos/2076090/pexels-photo-2076090.jpeg?auto=compress&cs=tinysrgb&w=600', label: 'Natural Highlight' },\n  { src: 'https://images.pexels.com/photos/3065609/pexels-photo-3065609.jpeg?auto=compress&cs=tinysrgb&w=600', label: 'Soft Wave Perm' },\n  { src: 'https://images.pexels.com/photos/1484808/pexels-photo-1484808.jpeg?auto=compress&cs=tinysrgb&w=600', label: 'Dark Ash Color' },\n  { src: 'https://images.pexels.com/photos/3992855/pexels-photo-3992855.jpeg?auto=compress&cs=tinysrgb&w=600', label: 'Sleek Straight' },\n  { src: 'https://images.pexels.com/photos/2688182/pexels-photo-2688182.jpeg?auto=compress&cs=tinysrgb&w=600', label: 'Beige Brown' },\n]\n</script>\n\n<template>\n  <section id=\"works\" class=\"bg-blanc-light py-28 md:py-40 px-6\">\n    <div ref=\"target\" class=\"max-w-5xl mx-auto\">\n\n      <!-- Heading -->\n      <div class=\"mb-16\">\n        <p :class=\"['reveal font-josefin text-[10px] tracking-[0.5em] text-blanc-accent mb-4', inView && 'in-view']\">\n          WORKS\n        </p>\n        <h2 :class=\"['reveal reveal-delay-1 font-garamond text-4xl md:text-5xl italic font-light text-blanc-primary', inView && 'in-view']\">\n          Style Gallery\n        </h2>\n      </div>\n\n      <!-- Grid -->\n      <div class=\"grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4\">\n        <div\n          v-for=\"(w, i) in works\"\n          :key=\"w.label\"\n          :class=\"[\n            'reveal',\n            `reveal-delay-${Math.min(i % 3 + 1, 4)}`,\n            inView && 'in-view',\n            'group relative overflow-hidden aspect-[3/4]',\n          ]\"\n        >\n          <img\n            :src=\"w.src\"\n            :alt=\"w.label\"\n            class=\"w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105\"\n          />\n          <!-- Hover overlay -->\n          <div class=\"absolute inset-0 bg-blanc-primary/60 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-end p-5\">\n            <p class=\"font-josefin text-blanc-white text-[11px] tracking-[0.3em]\">{{ w.label.toUpperCase() }}</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\nconst { target, inView } = useInView()\n\nconst stylists = [\n  {\n    name: '佐々木 麻衣',\n    nameEn: 'Mai Sasaki',\n    role: 'Senior Stylist',\n    specialty: 'カット・カラー',\n    bio: '都内有名サロンで10年の経験を積み、2020年よりatelier BLANCに参加。骨格診断カラーリストの資格を持ち、一人ひとりの肌トーンに合ったカラーを提案することが得意。',\n    src: 'https://images.pexels.com/photos/1303081/pexels-photo-1303081.jpeg?auto=compress&cs=tinysrgb&w=600',\n  },\n  {\n    name: '田中 理沙',\n    nameEn: 'Risa Tanaka',\n    role: 'Stylist',\n    specialty: 'パーマ・トリートメント',\n    bio: 'ヘアケアスペシャリストとして、髪質改善に特化した施術を行う。傷んだ髪を再生させるトリートメント技術と、自然なウェーブを作るパーマを得意とする。',\n    src: 'https://images.pexels.com/photos/1239291/pexels-photo-1239291.jpeg?auto=compress&cs=tinysrgb&w=600',\n  },\n]\n</script>\n\n<template>\n  <section id=\"stylist\" class=\"bg-blanc-bg py-28 md:py-40 px-6\">\n    <div ref=\"target\" class=\"max-w-5xl mx-auto\">\n\n      <!-- Heading -->\n      <div class=\"mb-16\">\n        <p :class=\"['reveal font-josefin text-[10px] tracking-[0.5em] text-blanc-accent mb-4', inView && 'in-view']\">\n          STYLIST\n        </p>\n        <h2 :class=\"['reveal reveal-delay-1 fo