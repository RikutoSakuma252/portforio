---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Story from '../components/Story.astro';
import MenuTabs from '../components/MenuTabs';
import Gallery from '../components/Gallery.astro';
import Wine from '../components/Wine.astro';
import Space from '../components/Space.astro';
import Voice from '../components/Voice.astro';
import Reserve from '../components/Reserve.astro';
import Access from '../components/Access.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Story />

    <!-- Menu section with React Island -->
    <section
      id="menu"
      class="py-24 md:py-36 bg-light-section"
      aria-labelledby="menu-heading"
    >
      <div class="max-w-6xl mx-auto px-6 md:px-12">
        <div class="mb-14">
          <p class="font-sub text-[0.6rem] tracking-cinzel uppercase text-dark-text/40 mb-4 flex items-center gap-3">
            <span class="w-6 h-px bg-dark-text/30"></span>Menu
          </p>
          <h2
            id="menu-heading"
            class="font-display text-[clamp(1.8rem,3.5vw,3rem)] italic text-dark-text"
          >
            コースメニュー
          </h2>
        </div>

        <!-- React Island: tab switching is interactive -->
        <MenuTabs client:load />
      </div>
    </section>

    <Gallery />
    <Wine />
    <Space />
    <Voice />
    <Reserve />
    <Access />
  </main>
  <Footer />
</Layout>
