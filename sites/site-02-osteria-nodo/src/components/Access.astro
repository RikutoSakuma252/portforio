---
---
<section id="access" class="py-24 md:py-36 bg-surface" aria-labelledby="access-heading">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">

      <!-- Info -->
      <div>
        <p class="font-sub text-[0.6rem] tracking-cinzel uppercase text-gold mb-4 reveal flex items-center gap-3">
          <span class="w-6 h-px bg-gold"></span>Access
        </p>
        <h2 id="access-heading" class="font-display text-[clamp(1.8rem,3.5vw,3rem)] italic text-cream mb-10 reveal reveal-delay-1">
          お越しの際は
        </h2>

        <dl class="space-y-0 reveal reveal-delay-2">
          {[
            { dt: '住所',     dd: '東京都〇〇区〇〇X-X-X\n[placeholder]' },
            { dt: '最寄り駅', dd: '地下鉄〇〇駅 徒歩3分' },
            { dt: '電話',     dd: '[placeholder]' },
            { dt: 'ランチ',   dd: '12:00 — 14:00（L.O. 13:30）' },
            { dt: 'ディナー', dd: '18:00 — 22:00（L.O. 21:00）' },
            { dt: '定休日',   dd: '火曜日' },
            { dt: '備考',     dd: '完全予約制 · 2名様より承ります' },
          ].map(({ dt, dd }) => (
            <div class="flex gap-6 py-4 border-b border-gold/10">
              <dt class="font-sub text-[0.55rem] tracking-cinzel uppercase text-gold flex-shrink-0 w-20 pt-0.5">{dt}</dt>
              <dd class="font-body text-[0.85rem] text-muted leading-relaxed whitespace-pre-line">{dd}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Map -->
      <div class="reveal reveal-delay-2">
        <div class="border border-gold/15 overflow-hidden">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3240.827!2d139.7015!3d35.6762!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60188b563b00109f%3A0x337328def1e2ab26!2z5p2x5Lqs6aeF!5e0!3m2!1sja!2sjp!4v1"
            width="100%"
            height="420"
            style="border:0;filter:sepia(0.4) contrast(1.1) brightness(0.85);"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="OSTERIA NODO アクセスマップ"
          ></iframe>
        </div>
      </div>

    </div>
  </div>
</section>
