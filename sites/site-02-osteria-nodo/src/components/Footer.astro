---
<footer class="bg-bg border-t border-gold/10 py-14 px-6 md:px-12">
  <div class="max-w-6xl mx-auto flex flex-col items-center text-center gap-5">

    <!-- Logo -->
    <div>
      <p class="font-sub text-[0.5rem] tracking-[0.6em] uppercase text-muted mb-1">OSTERIA</p>
      <p class="font-display font-bold italic text-3xl text-cream" style="text-shadow: 0 0 30px rgba(201,168,76,0.2);">NODO</p>
    </div>

    <!-- Ornament -->
    <div class="ornament w-40" aria-hidden="true">
      <span class="font-sub text-[0.45rem] text-gold">✦</span>
    </div>

    <!-- Address -->
    <p class="font-body text-[0.72rem] text-muted/50 tracking-wide">
      東京都〇〇区〇〇 &nbsp;·&nbsp; 18:00–22:00 &nbsp;·&nbsp; 火曜定休
    </p>

    <!-- SNS -->
    <nav class="flex items-center gap-6" aria-label="SNSリンク">
      <a
        href="#"
        class="font-sub text-[0.5rem] tracking-cinzel uppercase text-muted/50 hover:text-gold transition-colors duration-300"
        aria-label="Instagram（準備中）"
      >
        Instagram
      </a>
      <span class="text-gold/20 text-xs" aria-hidden="true">/</span>
      <a
        href="#"
        class="font-sub text-[0.5rem] tracking-cinzel uppercase text-muted/50 hover:text-gold transition-colors duration-300"
        aria-label="Facebook（準備中）"
      >
        Facebook
      </a>
    </nav>

    <!-- Copyright -->
    <p class="font-body text-[0.62rem] text-muted/30 tracking-wider mt-2">
      <small>&copy; 2024 OSTERIA NODO. All rights reserved.</small>
    </p>
  </div>
</footer>
