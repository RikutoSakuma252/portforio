---
const reviews = [
  {
    text: '結婚記念日に伺いました。シェフのおまかせコースは、一皿ごとに驚きと感動があり、忘れられない夜になりました。',
    name: 'M.T. 様（40代・ご夫婦）',
    stars: 5,
  },
  {
    text: '接待でご利用。個室でゆっくりと商談でき、料理・ワインともに満足いただけました。次回もぜひ利用したいです。',
    name: 'K.S. 様（50代・接待利用）',
    stars: 5,
  },
  {
    text: 'パスタの種類と質が素晴らしい。特にオレキエッテは、イタリアで食べた味を思い出しました。ワインのセレクションも最高。',
    name: 'A.Y. 様（30代・リピーター）',
    stars: 5,
  },
];
---

<section class="py-24 md:py-36 bg-surface" aria-labelledby="voice-heading">
  <div class="max-w-6xl mx-auto px-6 md:px-12">

    <div class="text-center mb-16">
      <p class="font-sub text-[0.6rem] tracking-cinzel uppercase text-gold mb-4 reveal">
        ✦ Guest Voice ✦
      </p>
      <h2 id="voice-heading" class="font-display text-[clamp(1.8rem,3.5vw,3rem)] italic text-cream reveal reveal-delay-1">
        ご来店のお客様から
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {reviews.map((review, i) => (
        <article
          class={`relative p-8 border border-gold/15 hover:border-gold/35 transition-colors duration-400 reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}
        >
          <!-- Large gold quote mark -->
          <span
            class="absolute top-4 right-6 font-display text-7xl leading-none text-gold/10 select-none pointer-events-none"
            aria-hidden="true"
          >
            "
          </span>

          <!-- Stars -->
          <div class="flex gap-1 mb-5" role="img" aria-label={`${review.stars}つ星評価`}>
            {Array.from({ length: review.stars }).map(() => (
              <span class="text-gold text-xs">★</span>
            ))}
          </div>

          <p class="font-body text-[0.85rem] text-muted leading-[2] mb-6 relative z-10">
            {review.text}
          </p>

          <footer>
            <p class="font-sub text-[0.55rem] tracking-cinzel uppercase text-gold/60">{review.name}</p>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
