---
---
<section
  id="reserve"
  class="relative py-36 md:py-48 bg-bg overflow-hidden"
  aria-labelledby="reserve-heading"
>
  <!-- Atmospheric gold glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(201,168,76,0.07) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Decorative large text -->
  <p
    class="absolute inset-x-0 top-1/2 -translate-y-1/2 text-center font-display font-bold italic text-[clamp(4rem,15vw,14rem)] text-cream/[0.03] leading-none select-none pointer-events-none"
    aria-hidden="true"
  >
    NODO
  </p>

  <div class="relative max-w-2xl mx-auto px-6 md:px-12 text-center">
    <p class="font-sub text-[0.6rem] tracking-cinzel uppercase text-gold mb-6 reveal">
      ✦ Reservation ✦
    </p>
    <h2
      id="reserve-heading"
      class="font-display text-[clamp(1.8rem,4vw,3.5rem)] italic text-cream mb-4 reveal reveal-delay-1"
    >
      特別な夜を、<br>ご一緒に。
    </h2>
    <p class="font-body text-[0.85rem] text-muted mb-12 leading-relaxed reveal reveal-delay-2">
      完全予約制・2名様よりご利用いただけます。<br>
      お電話またはウェブフォームよりご予約ください。
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal reveal-delay-2">
      <a
        href="#"
        class="inline-flex items-center gap-3 font-sub text-[0.65rem] tracking-cinzel uppercase px-10 py-4 bg-gold text-bg hover:bg-gold-light transition-colors duration-300 w-full sm:w-auto justify-center"
      >
        <!-- Phone icon -->
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.07 1.2 2 2 0 012.06 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/>
        </svg>
        お電話でご予約 [placeholder]
      </a>
      <a
        href="#"
        class="inline-flex items-center gap-3 font-sub text-[0.65rem] tracking-cinzel uppercase px-10 py-4 border border-gold text-gold hover:bg-gold/10 transition-colors duration-300 w-full sm:w-auto justify-center"
      >
        ウェブでご予約
      </a>
    </div>

    <!-- Hours -->
    <div class="mt-14 pt-8 border-t border-gold/15 reveal reveal-delay-3">
      <div class="grid grid-cols-2 gap-6 text-center max-w-xs mx-auto">
        <div>
          <p class="font-sub text-[0.5rem] tracking-cinzel uppercase text-gold mb-2">Lunch</p>
          <p class="font-body text-[0.82rem] text-muted">12:00 — 14:00</p>
        </div>
        <div>
          <p class="font-sub text-[0.5rem] tracking-cinzel uppercase text-gold mb-2">Dinner</p>
          <p class="font-body text-[0.82rem] text-muted">18:00 — 22:00</p>
        </div>
      </div>
      <p class="font-sub text-[0.5rem] tracking-cinzel uppercase text-muted/50 mt-4">火曜定休</p>
    </div>
  </div>
</section>
