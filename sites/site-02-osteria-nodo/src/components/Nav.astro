---
---
<nav
  id="nav"
  class="fixed inset-x-0 top-0 z-50 flex items-center justify-between px-8 md:px-16 py-5 transition-all duration-500"
>
  <!-- Logo -->
  <a href="#" class="font-sub text-sm tracking-cinzel text-cream uppercase" aria-label="OSTERIA NODO トップへ">
    NODO
  </a>

  <!-- Desktop links -->
  <ul class="hidden md:flex items-center gap-8 list-none" role="list">
    {['Story', 'Menu', 'Gallery', 'Reserve', 'Access'].map((item) => (
      <li>
        <a
          href={`#${item.toLowerCase()}`}
          class="font-sub text-[0.65rem] tracking-cinzel uppercase text-cream/70 hover:text-gold transition-colors duration-300 relative group"
        >
          {item}
          <span class="absolute -bottom-1 left-0 w-0 h-px bg-gold transition-all duration-400 group-hover:w-full"></span>
        </a>
      </li>
    ))}
  </ul>

  <!-- Reserve CTA (desktop) -->
  <a
    href="#reserve"
    class="hidden md:inline-flex items-center gap-2 font-sub text-[0.6rem] tracking-cinzel uppercase px-5 py-2.5 border border-gold/60 text-gold hover:bg-gold hover:text-bg transition-all duration-300"
  >
    ご予約
  </a>

  <!-- Mobile toggle -->
  <button
    id="navToggle"
    class="md:hidden flex flex-col gap-[5px] p-2"
    aria-label="メニューを開く"
    aria-expanded="false"
  >
    <span class="block w-5 h-px bg-cream transition-transform duration-300"></span>
    <span class="block w-5 h-px bg-cream transition-transform duration-300"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div
  id="mobileMenu"
  class="fixed inset-0 z-40 bg-bg/98 backdrop-blur-sm flex flex-col items-center justify-center gap-10 opacity-0 pointer-events-none transition-opacity duration-400"
  aria-hidden="true"
>
  {['Story', 'Menu', 'Gallery', 'Reserve', 'Access'].map((item) => (
    <a
      href={`#${item.toLowerCase()}`}
      class="nav-mobile-link font-sub text-2xl tracking-cinzel uppercase text-cream/80 hover:text-gold transition-colors duration-300"
    >
      {item}
    </a>
  ))}
</div>

<script>
  const nav       = document.getElementById('nav')!;
  const toggle    = document.getElementById('navToggle')!;
  const menu      = document.getElementById('mobileMenu')!;
  const [bar1, bar2] = toggle.querySelectorAll('span');

  // Scroll state
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav.classList.add('bg-bg/90', 'backdrop-blur-md', 'border-b', 'border-gold/10');
    } else {
      nav.classList.remove('bg-bg/90', 'backdrop-blur-md', 'border-b', 'border-gold/10');
    }
  }, { passive: true });

  // Mobile toggle
  let open = false;
  toggle.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));
    menu.setAttribute('aria-hidden', String(!open));
    menu.classList.toggle('opacity-0', !open);
    menu.classList.toggle('pointer-events-none', !open);
    document.body.style.overflow = open ? 'hidden' : '';
    bar1.style.transform = open ? 'translateY(7px) rotate(45deg)' : '';
    bar2.style.transform = open ? 'translateY(-7px) rotate(-45deg)' : '';
  });

  // Close on link click
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      open = false;
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
      bar1.style.transform = '';
      bar2.style.transform = '';
    });
  });

  // Close on Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && open) toggle.click();
  });

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', e => {
      const id = (anchor as HTMLAnchorElement).getAttribute('href');
      if (!id || id === '#') return;
      const target = document.querySelector(id);
      if (!target) return;
      e.preventDefault();
      const offset = nav.offsetHeight;
      window.scrollTo({ top: (target as HTMLElement).offsetTop - offset, behavior: 'smooth' });
    });
  });

  // IntersectionObserver reveals
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  reveals.forEach(el => observer.observe(el));
</script>
